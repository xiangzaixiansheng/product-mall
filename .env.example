# Environment Configuration

# JWT Secret Key (REQUIRED - generates tokens for authentication)
JWT_SECRET_KEY=your-secret-key-here

# Application Environment (dev/prod)
ENV=dev

# Session * (REQUIRED in production)
SESSION_*=your-session-*-here

# Server Configuration
HTTP_PORT=:3000

# MySQL Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=product_mall

# Redis Configuration
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Email Configuration
VALID_EMAIL=http://localhost:3000/api/v1/user/valid_email
SMTP_HOST=smtp.example.com
SMTP_EMAIL=your-email@example.com
SMTP_PASSWORD=your-email-password

# Qiniu OSS Configuration
QINIU_ACCESS_KEY=your-access-key
QINIU_SECRET_KEY=your-secret-key
QINIU_BUCKET=your-bucket-name
QINIU_SERVER=s3-cn-south-1.qiniucs.com